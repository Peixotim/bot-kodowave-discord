# --- FASE DE CONSTRUÇÃO (BUILDER) ---
FROM node:22-slim AS builder

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

# Ativa o corepack para usar o pnpm
RUN corepack enable

# Instala Python e ferramentas de compilação necessárias para o node-gyp (@discordjs/opus)
RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copia arquivos de configuração de dependências
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml* ./

# Agora o pnpm install conseguirá compilar o @discordjs/opus
RUN pnpm install --frozen-lockfile

COPY . .

RUN pnpm run build

# Limpa dependências de dev e reinstala apenas produção para diminuir o tamanho final
RUN rm -rf node_modules && pnpm install --prod --frozen-lockfile


# --- FASE DE EXECUÇÃO (RUNNER) ---
FROM node:22-slim AS runner

# No runner, mantemos o ffmpeg (essencial para música) 
# O Python geralmente não é mais necessário aqui após a compilação, 
# mas mantive conforme seu código original caso tenha algum script externo.
RUN apt-get update && apt-get install -y \
    ffmpeg \
    python3 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copia apenas o necessário do builder
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./package.json

ENV NODE_ENV=production
ENV NODE_OPTIONS="--no-warnings"

USER node

CMD ["node", "dist/index.js"]